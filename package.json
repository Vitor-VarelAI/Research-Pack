{
  "name": "scrape-agent",
  "version": "0.1.0",
  "description": "Backend-first scrape agent MVP powered by Firecrawl",
  "type": "module",
  "bin": {
    "scrape-agent": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:editorial": "scripts/editorial-lint.sh",
    "lint:fact": "scripts/fact-check.sh",
    "lint:ptpt": "scripts/ptpt-lint.sh",
    "qa:content": "scripts/content-qa.sh"
  },
  "keywords": [
    "scraping",
    "firecrawl",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
